{
  "schemaVersion": 1,
  "defaultMode": "disabled",
  "local": {
    "basePath": "/api/auth",
    "secretEnvs": [
      "QUANTPILOT_AUTH_SECRET",
      "BETTER_AUTH_SECRET"
    ],
    "baseUrlEnv": "BETTER_AUTH_URL",
    "allowSignUp": false,
    "session": {
      "expiresInSeconds": 43200,
      "updateAgeSeconds": 300,
      "freshAgeSeconds": 1800,
      "rememberMe": false
    },
    "password": {
      "minLength": 12,
      "maxLength": 128,
      "argon2id": {
        "memoryCostKiB": 19456,
        "timeCost": 2,
        "parallelism": 1,
        "outputLength": 32
      }
    },
    "rateLimit": {
      "windowSeconds": 60,
      "maxRequests": 60,
      "signInWindowSeconds": 60,
      "signInMaxRequests": 5
    },
    "retention": {
      "auditDays": 180,
      "expiredRecordGraceSeconds": 3600
    },
    "bootstrap": {
      "emailEnv": "QUANTPILOT_AUTH_ADMIN_EMAIL",
      "passwordEnv": "QUANTPILOT_AUTH_ADMIN_PASSWORD",
      "nameEnv": "QUANTPILOT_AUTH_ADMIN_NAME",
      "developmentDefaults": {
        "login": "admin",
        "email": "admin@quantpilot.local",
        "password": "admin",
        "name": "QuantPilot 管理员"
      }
    },
    "publicPaths": [
      "/login",
      "/api/auth",
      "/api/health",
      "/api/ready"
    ]
  }
}
