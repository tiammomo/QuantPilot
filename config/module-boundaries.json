{
  "version": 1,
  "modules": [
    {
      "id": "shared-kernel",
      "name": "共享内核",
      "summary": "跨模块稳定类型、配置、工具函数和无业务状态的基础能力。",
      "owner": "platform",
      "paths": [
        "src/types/**",
        "src/lib/config/**",
        "src/lib/utils.ts",
        "src/lib/runtime-degradation.ts"
      ],
      "dependsOn": [],
      "publicSurface": [
        "@/types/shared",
        "@/types/client",
        "@/types/server",
        "@/lib/utils",
        "@/lib/config/constants"
      ]
    },
    {
      "id": "ui-kit",
      "name": "通用 UI 组件",
      "summary": "按钮、输入、弹窗、选择器等无领域知识的基础 UI。",
      "owner": "frontend-platform",
      "paths": [
        "src/components/ui/**"
      ],
      "dependsOn": [
        "shared-kernel"
      ],
      "publicSurface": [
        "@/components/ui/button",
        "@/components/ui/input",
        "@/components/ui/select"
      ]
    },
    {
      "id": "product-shell",
      "name": "产品壳层",
      "summary": "首页、导航、布局、主题和平台入口编排。",
      "owner": "frontend-platform",
      "paths": [
        "src/app/page.tsx",
        "src/app/layout.tsx",
        "src/app/globals.css",
        "src/app/error.tsx",
        "src/app/global-error.tsx",
        "src/app/not-found.tsx",
        "src/components/layout/**",
        "src/components/theme/**"
      ],
      "dependsOn": [
        "shared-kernel",
        "ui-kit",
        "platform-core",
        "quant-core"
      ],
      "publicSurface": [
        "@/components/layout/PageHeader",
        "@/components/layout/SubNav"
      ]
    },
    {
      "id": "platform-core",
      "name": "平台核心",
      "summary": "项目、设置、Token、服务目录、GitHub/Vercel 集成和工作空间基础状态。",
      "owner": "platform",
      "paths": [
        "src/lib/platform/**",
        "src/lib/services/project.ts",
        "src/lib/services/project-services.ts",
        "src/lib/services/settings.ts",
        "src/lib/services/tokens.ts",
        "src/lib/services/env.ts",
        "src/lib/services/git.ts",
        "src/lib/services/github.ts",
        "src/lib/services/vercel.ts",
        "src/lib/services/service-integration.ts",
        "src/lib/services/supabase.ts",
        "src/lib/services/file-browser.ts",
        "src/app/api/projects/**",
        "src/app/api/settings/**",
        "src/app/api/tokens/**",
        "src/app/api/infrastructure/**"
      ],
      "dependsOn": [
        "shared-kernel",
        "quant-core"
      ],
      "publicSurface": [
        "@/lib/platform/service-catalog",
        "@/lib/services/project",
        "@/lib/services/settings"
      ],
      "migrationNotes": [
        "project.ts 仍引用 quant capability 默认值；后续应把项目默认量化配置移到 quant-core 的 public adapter。"
      ]
    },
    {
      "id": "agent-runtime",
      "name": "Agent 运行时",
      "summary": "Claude/Codex/CLI 适配、流式消息、预览、用户请求和技能注入。",
      "owner": "agent-platform",
      "paths": [
        "src/lib/services/agent-runtime.ts",
        "src/lib/services/message.ts",
        "src/lib/services/stream.ts",
        "src/lib/services/preview.ts",
        "src/lib/services/user-requests.ts",
        "src/lib/services/claude-skills.ts",
        "src/lib/services/quant-image-mcp.ts",
        "src/lib/services/cli/**",
        "src/app/api/chat/**",
        "src/app/[project_id]/**",
        "src/components/chat/**"
      ],
      "dependsOn": [
        "shared-kernel",
        "platform-core",
        "quant-core"
      ],
      "publicSurface": [
        "@/lib/services/agent-runtime",
        "@/lib/services/cli/claude",
        "@/lib/services/claude-skills"
      ]
    },
    {
      "id": "quant-core",
      "name": "量化核心",
      "summary": "量化能力、策略、数据预取、工作空间证据、验证和技能治理。",
      "owner": "quant-platform",
      "paths": [
        "src/lib/quant/**",
        "src/lib/services/quant-image-mcp.ts",
        "src/app/api/quant/**",
        "src/app/api/research/**",
        "src/app/strategy-platform/**",
        "src/app/research-reports/**",
        "src/app/data-platform/**",
        "src/app/capabilities/**",
        "src/app/strategies/**",
        "src/components/quant/skills-*.tsx",
        "src/components/quant/workspace-*.tsx",
        "src/components/quant/console-primitives.tsx"
      ],
      "dependsOn": [
        "shared-kernel",
        "platform-core",
        "agent-runtime",
        "ui-kit"
      ],
      "publicSurface": [
        "@/lib/quant/capabilities",
        "@/lib/quant/research-reports",
        "@/lib/quant/strategies",
        "@/lib/quant/workspace",
        "@/lib/quant/validation"
      ],
      "migrationNotes": [
        "strategies.ts 已拆出 strategy-types / strategy-catalog / strategy-scan-repository / strategy-readiness；StrategyPlatformClient 已拆出 helpers、FinancialKnowledgeView、UniverseView、StockKlineDetail、SectorCapitalFlowView、FactorCatalogView、FoundationView，后续继续拆 dialogs、hooks、market API client 和 response mappers。"
      ]
    },
    {
      "id": "eval-core",
      "name": "评测核心",
      "summary": "评测集、用例、运行历史、评测器、报告和质量门。",
      "owner": "eval-platform",
      "paths": [
        "src/lib/eval/**",
        "src/app/eval-platform/**",
        "src/app/evals/**",
        "src/app/api/evals/**",
        "src/components/quant/eval-*.tsx",
        "scripts/evals/**",
        "scripts/checks/check-eval-*.js",
        "scripts/checks/check-quant-benchmark-coverage.js",
        "docs/evals-guide.md"
      ],
      "dependsOn": [
        "shared-kernel",
        "platform-core",
        "quant-core",
        "ui-kit"
      ],
      "publicSurface": [
        "@/lib/eval",
        "@/components/quant/eval-console-primitives"
      ],
      "migrationNotes": [
        "eval-core 已迁出 quant 目录；cases/sets 已拆入 cases.ts，paths 和 runtime-utils 已共享。runtime.ts 仍需继续拆 runs / queue / reports / repairs / scheduling。"
      ]
    },
    {
      "id": "ops-core",
      "name": "运维核心",
      "summary": "Docker、服务健康、基础设施、工作空间健康和可观测性入口。",
      "owner": "ops-platform",
      "paths": [
        "src/lib/ops/**",
        "src/app/ops-platform/**",
        "src/app/api/ops/**",
        "src/app/api/observability/**",
        "src/components/quant/ops-*.tsx",
        "deploy/observability/**"
      ],
      "dependsOn": [
        "shared-kernel",
        "platform-core",
        "quant-core",
        "ui-kit"
      ],
      "publicSurface": [
        "@/lib/ops/ops-platform",
        "@/lib/ops/infrastructure-health"
      ]
    },
    {
      "id": "market-data-backend",
      "name": "Python 市场数据后端",
      "summary": "FastAPI、行情 provider、TimescaleDB 事实库、Redis 缓存、ClickHouse 分析层和回测。",
      "owner": "backend-platform",
      "paths": [
        "services/market-data/**"
      ],
      "dependsOn": [],
      "publicSurface": [
        "services/market-data/src/quantpilot_market_data/routers",
        "services/market-data/src/quantpilot_market_data/services",
        "services/market-data/src/quantpilot_market_data/repositories"
      ],
      "migrationNotes": [
        "database.py 已降为兼容门面；analytics、bars、coverage、foundation、ingestion、sector_flow、screener、universes、upserts 已迁入 repositories/。新增 SQL 禁止写入 database.py，必须优先落到对应 repository。"
      ]
    }
  ],
  "rules": {
    "forbiddenImports": [
      {
        "from": "src/lib/**",
        "to": "src/app/**",
        "reason": "领域和服务层不能反向依赖 Next.js 页面。"
      },
      {
        "from": "src/components/ui/**",
        "to": "src/app/**",
        "reason": "通用 UI 不能依赖页面层。"
      },
      {
        "from": "src/components/ui/**",
        "to": "src/lib/quant/**",
        "reason": "通用 UI 不能携带量化领域知识。"
      },
      {
        "from": "src/components/ui/**",
        "to": "src/lib/services/**",
        "reason": "通用 UI 不能直接依赖运行时服务。"
      },
      {
        "from": "src/components/ui/**",
        "to": "src/lib/ops/**",
        "reason": "通用 UI 不能直接依赖运维领域。"
      },
      {
        "from": "services/market-data/**",
        "to": "src/**",
        "reason": "Python 后端不能依赖 Next.js 前端源码。"
      }
    ],
    "largeFileBudgets": [
      {
        "path": "services/market-data/src/quantpilot_market_data/database.py",
        "maxLines": 400,
        "targetLines": 180,
        "nextAction": "保持兼容门面，不再承接 SQL；新增持久化能力必须进入 repositories/，再由 service 或 legacy facade 显式导出。"
      },
      {
        "path": "src/app/strategy-platform/StrategyPlatformClient.tsx",
        "maxLines": 6500,
        "targetLines": 1600,
        "nextAction": "已拆 helpers、Knowledge、Universe、Kline、Sector、Factor、Foundation 视图；继续拆 dialogs、hooks 和 tables。"
      },
      {
        "path": "src/lib/quant/strategies.ts",
        "maxLines": 4800,
        "targetLines": 1800,
        "nextAction": "已拆 catalog/types/scan repository/readiness；继续拆 market API client、mappers 和 dashboard service。"
      },
      {
        "path": "src/lib/eval/runtime.ts",
        "maxLines": 1800,
        "targetLines": 1400,
        "nextAction": "已拆 cases/sets、paths 和 runtime-utils；继续拆 runs / queue / reports / repairs / scheduling，保留 src/lib/eval 作为唯一公开入口。"
      }
    ]
  }
}
