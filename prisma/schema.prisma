// ============================================================
// Project Authentication (Better Auth)
// ============================================================

model AuthUser {
  id                  String                   @id
  name                String
  email               String                   @unique
  emailVerified       Boolean                  @default(false) @map("email_verified")
  image               String?
  role                String                   @default("member")
  banned              Boolean                  @default(false)
  banReason           String?                  @map("ban_reason")
  banExpires          DateTime?                @map("ban_expires")
  mustChangePassword  Boolean                  @default(false) @map("must_change_password")
  lastLoginAt         DateTime?                @map("last_login_at")
  passwordChangedAt   DateTime?                @map("password_changed_at")
  permissionProfileId String?                  @map("permission_profile_id")
  quotaProfileId      String?                  @map("quota_profile_id")
  accessVersion       Int                      @default(0) @map("access_version")
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")
  sessions            AuthSession[]
  accounts            AuthAccount[]
  ownedProjects       Project[]                @relation("ProjectOwner")
  projectMemberships  ProjectMembership[]
  auditEvents         AuthAuditEvent[]         @relation("AuthAuditActor")
  permissionProfile   PermissionProfile?       @relation(fields: [permissionProfileId], references: [id], onDelete: SetNull)
  permissionOverrides UserPermissionOverride[]
  quotaProfile        QuotaProfile?            @relation(fields: [quotaProfileId], references: [id], onDelete: SetNull)
  quotaOverrides      UserQuotaOverride[]
  usageEvents         UsageEvent[]             @relation("UsageActor")
  usageBuckets        UsageBucket[]
  quotaReservations   QuotaReservation[]
  initiatedRequests   UserRequest[]            @relation("UserRequestActor")
  initiatedAgentRuns  AgentRun[]               @relation("AgentRunActor")

  @@index([role])
  @@index([banned])
  @@index([permissionProfileId])
  @@index([quotaProfileId])
  @@map("auth_users")
}

model AuthSession {
  id             String   @id
  expiresAt      DateTime @map("expires_at")
  token          String   @unique
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  userId         String   @map("user_id")
  impersonatedBy String?  @map("impersonated_by")
  user           AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthAccount {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("auth_accounts")
}

model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("auth_verifications")
}

model AuthRateLimit {
  id          String @id
  key         String @unique
  count       Int
  lastRequest BigInt @map("last_request")

  @@map("auth_rate_limits")
}

model ProjectMembership {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  role      String   @default("viewer")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
  @@map("project_memberships")
}

model AuthAuditEvent {
  id          String    @id @default(cuid())
  actorUserId String?   @map("actor_user_id")
  eventType   String    @map("event_type")
  targetType  String?   @map("target_type")
  targetId    String?   @map("target_id")
  outcome     String
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")
  actor       AuthUser? @relation("AuthAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
  @@index([targetType, targetId])
  @@map("auth_audit_events")
}

// ============================================================
// Capability permissions
// ============================================================

model PermissionProfile {
  id          String                   @id @default(cuid())
  key         String                   @unique
  name        String
  description String?
  isDefault   Boolean                  @default(false) @map("is_default")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  grants      PermissionProfileGrant[]
  users       AuthUser[]

  @@index([isDefault])
  @@map("permission_profiles")
}

model PermissionProfileGrant {
  id            String            @id @default(cuid())
  profileId     String            @map("profile_id")
  permissionKey String            @map("permission_key")
  effect        String            @default("allow")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  profile       PermissionProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, permissionKey])
  @@index([permissionKey, effect])
  @@map("permission_profile_grants")
}

model UserPermissionOverride {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  permissionKey String    @map("permission_key")
  effect        String
  reason        String?
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionKey])
  @@index([permissionKey, effect])
  @@index([expiresAt])
  @@map("user_permission_overrides")
}

// ============================================================
// Usage quotas and idempotent metering
// ============================================================

model QuotaProfile {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String?
  isDefault   Boolean     @default(false) @map("is_default")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  rules       QuotaRule[]
  users       AuthUser[]

  @@index([isDefault])
  @@map("quota_profiles")
}

model QuotaRule {
  id                    String       @id @default(cuid())
  profileId             String       @map("profile_id")
  metric                String
  limit                 BigInt
  enforcement           String       @default("observe")
  windowType            String       @default("month") @map("window_type")
  windowSeconds         Int?         @map("window_seconds")
  reservationTtlSeconds Int          @default(900) @map("reservation_ttl_seconds")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")
  profile               QuotaProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, metric])
  @@index([metric, enforcement])
  @@map("quota_rules")
}

model UserQuotaOverride {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  metric                String
  isUnlimited           Boolean   @default(false) @map("is_unlimited")
  limit                 BigInt?
  enforcement           String    @default("observe")
  windowType            String    @default("month") @map("window_type")
  windowSeconds         Int?      @map("window_seconds")
  reservationTtlSeconds Int       @default(900) @map("reservation_ttl_seconds")
  reason                String?
  expiresAt             DateTime? @map("expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metric])
  @@index([metric, enforcement])
  @@index([expiresAt])
  @@map("user_quota_overrides")
}

model UsageBucket {
  id           String             @id @default(cuid())
  actorUserId  String             @map("actor_user_id")
  metric       String
  windowStart  DateTime           @map("window_start")
  windowEnd    DateTime           @map("window_end")
  used         BigInt             @default(0)
  reserved     BigInt             @default(0)
  version      Int                @default(0)
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  actor        AuthUser           @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  reservations QuotaReservation[]
  events       UsageEvent[]

  @@unique([actorUserId, metric, windowStart, windowEnd])
  @@index([metric, windowStart, windowEnd])
  @@index([actorUserId, windowEnd])
  @@map("usage_buckets")
}

model QuotaReservation {
  id                String                   @id @default(cuid())
  idempotencyKey    String                   @unique @map("idempotency_key")
  actorUserId       String                   @map("actor_user_id")
  projectId         String?                  @map("project_id")
  bucketId          String                   @map("bucket_id")
  metric            String
  reservedQuantity  BigInt                   @map("reserved_quantity")
  committedQuantity BigInt                   @default(0) @map("committed_quantity")
  status            String                   @default("active")
  policyLimit       BigInt?                  @map("policy_limit")
  policyEnforcement String                   @map("policy_enforcement")
  policyWindowType  String                   @map("policy_window_type")
  enforcementExempt Boolean                  @default(false) @map("enforcement_exempt")
  expiresAt         DateTime                 @map("expires_at")
  settledAt         DateTime?                @map("settled_at")
  releasedAt        DateTime?                @map("released_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")
  actor             AuthUser                 @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  project           Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  bucket            UsageBucket              @relation(fields: [bucketId], references: [id], onDelete: Restrict)
  usageEvent        UsageEvent?
  apiOperation      ApiIdempotencyOperation?

  @@index([actorUserId, metric, createdAt])
  @@index([status, expiresAt])
  @@index([projectId])
  @@map("quota_reservations")
}

model UsageEvent {
  id                String            @id @default(cuid())
  idempotencyKey    String            @unique @map("idempotency_key")
  actorUserId       String?           @map("actor_user_id")
  projectId         String?           @map("project_id")
  reservationId     String?           @unique @map("reservation_id")
  bucketId          String?           @map("bucket_id")
  metric            String
  quantity          BigInt
  sourceType        String            @map("source_type")
  sourceId          String?           @map("source_id")
  enforcementExempt Boolean           @default(false) @map("enforcement_exempt")
  occurredAt        DateTime          @map("occurred_at")
  metadata          Json              @default("{}")
  createdAt         DateTime          @default(now()) @map("created_at")
  actor             AuthUser?         @relation("UsageActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  project           Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reservation       QuotaReservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  bucket            UsageBucket?      @relation(fields: [bucketId], references: [id], onDelete: SetNull)

  @@index([actorUserId, metric, occurredAt])
  @@index([projectId, occurredAt])
  @@index([metric, occurredAt])
  @@index([sourceType, sourceId])
  @@index([bucketId])
  @@map("usage_events")
}

/// Durable replay ledger for explicitly idempotent, potentially expensive API
/// operations. Only payload hashes and bounded JSON responses are retained;
/// authentication headers and raw request bodies must never be stored here.
model ApiIdempotencyOperation {
  id                 String            @id @default(cuid())
  scope              String
  actorKey           String            @map("actor_key")
  idempotencyKeyHash String            @map("idempotency_key_hash")
  payloadHash        String            @map("payload_hash")
  status             String            @default("running")
  attempt            Int               @default(1)
  leaseExpiresAt     DateTime          @map("lease_expires_at")
  responseStatus     Int?              @map("response_status")
  responseBody       Json?             @map("response_body")
  responseBytes      Int?              @map("response_bytes")
  quotaReservationId String?           @unique @map("quota_reservation_id")
  quotaSettlement    Json?             @map("quota_settlement")
  quotaAccountedAt   DateTime?         @map("quota_accounted_at")
  errorCode          String?           @map("error_code")
  errorMessage       String?           @map("error_message")
  completedAt        DateTime?         @map("completed_at")
  retentionExpiresAt DateTime          @map("retention_expires_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  quotaReservation   QuotaReservation? @relation(fields: [quotaReservationId], references: [id], onDelete: SetNull)

  @@unique([scope, actorKey, idempotencyKeyHash])
  @@index([status, leaseExpiresAt])
  @@index([retentionExpiresAt])
  @@index([status, quotaAccountedAt])
  @@map("api_idempotency_operations")
}
