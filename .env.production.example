# QuantPilot strict production configuration template
# ===================================================
# Copy this file OUTSIDE the repository, replace every placeholder, then run:
#   npm run check:production -- --env-file /secure/path/quantpilot.env
# Inject the same public/build values at build time and all values at runtime.
# Prefer an orchestrator secret manager over a long-lived file.
#
# The template chooses the recommended topology: Qwen and daily DeepSeek through
# ModelPort, Memory enabled through a short-lived token broker. Alternative direct
# DeepSeek and Memory-disabled settings are documented inline and in
# docs/configuration.md. Do not commit the populated file.

# Runtime and canonical public origin
NODE_ENV=production
QUANTPILOT_DEGRADATION_MODE=strict
NEXT_PUBLIC_APP_URL=https://quantpilot.example.com
BETTER_AUTH_URL=https://quantpilot.example.com
QUANTPILOT_WEB_HOST=0.0.0.0
PORT=3000

# Authentication and browser security
QUANTPILOT_AUTH_SECRET=replace-with-32-plus-random-characters
QUANTPILOT_AUTH_MODE=local
QUANTPILOT_AUTH_SECURE_COOKIES=1
QUANTPILOT_SECURITY_HSTS=1
QUANTPILOT_AUTH_TRUSTED_ORIGINS=https://quantpilot.example.com
QUANTPILOT_AUTH_ALLOW_SIGNUP=0
QUANTPILOT_AUTH_REMEMBER_ME=0
QUANTPILOT_AUTH_AUDIT_RETENTION_DAYS=180
QUANTPILOT_AUTH_EXPIRED_RECORD_GRACE_SECONDS=3600

# Use --require-bootstrap only for the one-time administrator bootstrap. Remove
# both values from the long-running service environment after bootstrap.
QUANTPILOT_AUTH_ADMIN_EMAIL=admin@example.com
QUANTPILOT_AUTH_ADMIN_PASSWORD=replace-with-strong-bootstrap-password
QUANTPILOT_AUTH_ADMIN_NAME=QuantPilot 管理员

# Durable stores. PROJECTS_DIR must be shared by every pod allowed to execute the
# same project/namespace, and must survive application restarts.
DATABASE_URL=postgresql://quantpilot:replace-with-database-password@timescaledb:5432/quantpilot?schema=public
REDIS_URL=redis://redis:6379/0
PROJECTS_DIR=/var/lib/quantpilot/projects
ENCRYPTION_KEY=replace-with-64-hex-characters

# Required service topology
QUANTPILOT_DATABASE_ENABLED=1
QUANTPILOT_DATABASE_REQUIRED=1
QUANTPILOT_MARKET_API_ENABLED=1
QUANTPILOT_MARKET_API_REQUIRED=1
QUANTPILOT_MARKET_API_URL=http://market-data:8000
QUANTPILOT_MARKET_ADMIN_TOKEN=replace-with-32-plus-random-characters
QUANTPILOT_MARKET_MAINTENANCE_ENABLED=1
QUANTPILOT_MARKET_MAINTENANCE_UNIVERSE_ID=a-share-sample-research-pool
QUANTPILOT_MARKET_CALENDAR_LOOKBACK_DAYS=30
QUANTPILOT_MARKET_HISTORY_LOOKBACK_DAYS=14
QUANTPILOT_MARKET_MAINTENANCE_REQUEST_DELAY_SECONDS=0.2
QUANTPILOT_MARKET_MAINTENANCE_BATCH_DELAY_SECONDS=0.7
QUANTPILOT_MARKET_MAINTENANCE_BATCH_SIZE=25
QUANTPILOT_MARKET_MAINTENANCE_MAX_RETRIES=3
QUANTPILOT_MARKET_MAINTENANCE_POLL_INTERVAL_MS=2000
QUANTPILOT_MARKET_CALENDAR_TIMEOUT_MS=120000
QUANTPILOT_MARKET_INGESTION_TIMEOUT_MS=1800000
QUANTPILOT_MARKET_FRESHNESS_MIN_SYMBOLS=250
QUANTPILOT_REDIS_CACHE_ENABLED=1
QUANTPILOT_REDIS_REQUIRED=1
QUANTPILOT_OBSERVABILITY_ENABLED=1
QUANTPILOT_OBSERVABILITY_REQUIRED=1
QUANTPILOT_CLICKHOUSE_ENABLED=0
QUANTPILOT_CLICKHOUSE_REQUIRED=0

# Observability endpoints. Keep anonymous Grafana access disabled in production.
LOKI_URL=http://loki:3100
GRAFANA_ANONYMOUS_ENABLED=0
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password

# Model access — recommended topology
# MODELPORT_API_KEY is a scoped ModelPort client key. DeepSeek/Qwen upstream keys
# remain in ModelPort and must never be copied into QuantPilot.
MODELPORT_API_KEY=replace-with-production-modelport-client-key
QUANTPILOT_MODELPORT_URL=https://modelport.internal.example
QUANTPILOT_MODELPORT_ENABLED=1
QUANTPILOT_MODELPORT_REQUIRED=1
QUANTPILOT_MODELPORT_ORGANIZATION_ID=org_quantpilot
QUANTPILOT_MODELPORT_PROJECT_ID=prj_quantpilot
QUANTPILOT_MODELPORT_ENVIRONMENT_ID=env_production

QUANTPILOT_KNOWLEDGE_ENABLED=1
QUANTPILOT_KNOWLEDGE_REQUIRED=1
QUANTPILOT_KNOWLEDGE_API_URL=https://knowledge.internal.example
QUANTPILOT_KNOWLEDGE_PURPOSE=quant-research
QUANTPILOT_KNOWLEDGE_SPACES=https://knowledge.internal.example/spaces/quant-research
QUANTPILOT_KNOWLEDGE_PROJECT_SPACES_ENABLED=1
QUANTPILOT_KNOWLEDGE_PROJECT_SPACE_BASE_URL=https://knowledge.internal.example/spaces/quantpilot/projects
QUANTPILOT_KNOWLEDGE_TIMEOUT_MS=2000
QUANTPILOT_KNOWLEDGE_MAX_CONTEXT_CHARACTERS=8000
QUANTPILOT_KNOWLEDGE_BEARER_TOKEN=
QUANTPILOT_KNOWLEDGE_OAUTH_TOKEN_URL=https://identity.internal.example/oauth2/token
QUANTPILOT_KNOWLEDGE_OAUTH_CLIENT_ID=quantpilot
QUANTPILOT_KNOWLEDGE_OAUTH_CLIENT_SECRET=inject-from-secret-manager
QUANTPILOT_KNOWLEDGE_OAUTH_RESOURCE=https://knowledge.internal.example/akep/0.1
QUANTPILOT_KNOWLEDGE_OAUTH_SCOPE="akep:query akep:read akep:feedback"
QUANTPILOT_LLM_AGENT_ENABLED=1
QUANTPILOT_LLM_QUERY_REWRITE_ENABLED=1
QUANTPILOT_QUERY_REWRITE_LLM_TIMEOUT_MS=12000
QUANTPILOT_QUERY_REWRITE_LLM_MAX_RETRIES=0

# Optional official-direct DeepSeek profile. Inject this variable only when projects
# explicitly select `deepseek-v4-flash`. It does not change the Qwen global default.
# DEEPSEEK_API_KEY=inject-with-your-secret-manager

# Evolvable User Memory — production-enabled example
# ENABLED=0 is a supported normal deployment and then every remaining MEMORY_* value
# may be omitted. REQUIRED=0 only permits degradation; it does not disable Memory.
QUANTPILOT_MEMORY_ENABLED=1
QUANTPILOT_MEMORY_REQUIRED=1
QUANTPILOT_MEMORY_REQUIRE_PRODUCTION_READY=1
QUANTPILOT_MEMORY_API_URL=https://memory.internal.example.com
QUANTPILOT_MEMORY_TENANT_ID=quantpilot-production
QUANTPILOT_MEMORY_TIMEOUT_MS=1200
QUANTPILOT_MEMORY_RECALL_LIMIT=6
QUANTPILOT_MEMORY_MAX_CONTEXT_CHARACTERS=2000
# Static QUANTPILOT_MEMORY_BEARER_TOKEN is forbidden for multi-user production.
QUANTPILOT_MEMORY_BEARER_TOKEN=
QUANTPILOT_MEMORY_TOKEN_BROKER_URL=https://identity.internal.example.com/memory-token
QUANTPILOT_MEMORY_TOKEN_BROKER_CLIENT_ID=quantpilot-production
QUANTPILOT_MEMORY_TOKEN_BROKER_CLIENT_SECRET=replace-with-token-broker-client-secret
QUANTPILOT_MEMORY_TOKEN_AUDIENCE=evolvable-memory-api
QUANTPILOT_MEMORY_PRODUCTION_PROBE_SUBJECT_ID=svc_quantpilot_readiness

# Host-level administration. The internal token API remains off unless a separately
# authenticated trusted control plane explicitly requires it.
QUANTPILOT_ADMIN_TOKEN=replace-with-32-plus-random-characters
QUANTPILOT_ENABLE_INTERNAL_TOKEN_API=0
QUANTPILOT_INTERNAL_API_TOKEN=

# Generated workspace isolation and distributed execution identity
QUANTPILOT_GENERATED_SANDBOX=1
QUANTPILOT_ALLOW_UNSANDBOXED_GENERATED_CODE=0
MOAGENT_WORKSPACE_NAMESPACE=quantpilot-production
MOAGENT_INSTANCE_ID=
MOAGENT_TIMEOUT_MS=1200000
MOAGENT_LEASE_TTL_MS=60000
MOAGENT_HEARTBEAT_INTERVAL_MS=15000
MOAGENT_DISPATCH_MODE=worker
MOAGENT_DISPATCH_LEASE_TTL_MS=120000
MOAGENT_DISPATCH_HEARTBEAT_INTERVAL_MS=30000
MOAGENT_DISPATCH_PENDING_ORPHAN_GRACE_MS=120000
MOAGENT_DISPATCH_RETRY_BASE_DELAY_MS=5000
MOAGENT_WORKER_POLL_INTERVAL_MS=1000
MOAGENT_WORKER_CONCURRENCY=2
MOAGENT_WORKER_CLAIM_BATCH_SIZE=20
MOAGENT_RESOURCE_LOCK_WAIT_MS=5000

# Release evaluation assurance. Paths must be mounted secrets, not repository files.
QUANTPILOT_REQUIRE_HIDDEN_EVAL=1
QUANTPILOT_REQUIRE_PRODUCTION_JUDGE_CALIBRATION=1
QUANTPILOT_REQUIRE_INDEPENDENT_JUDGE=1
QUANTPILOT_EVAL_DATASET_VISIBILITY=hidden
QUANTPILOT_REPLAY_HASH_KEY=replace-with-16-plus-random-characters
QUANTPILOT_HIDDEN_EVAL_CASES_PATH=/run/secrets/quantpilot-hidden-eval-cases.json
QUANTPILOT_EVAL_JUDGE_CALIBRATION_PATH=/run/secrets/quantpilot-judge-calibration.json
