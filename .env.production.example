# QuantPilot production configuration template.
# Copy this file outside the repository, replace every placeholder, run
# `npm run check:production -- --env-file /secure/path/quantpilot.env`, then
# inject the same values into both build and runtime environments.

NODE_ENV=production
QUANTPILOT_DEGRADATION_MODE=strict
NEXT_PUBLIC_APP_URL=https://quantpilot.example.com
BETTER_AUTH_URL=https://quantpilot.example.com
QUANTPILOT_WEB_HOST=0.0.0.0
PORT=3000

QUANTPILOT_AUTH_MODE=local
QUANTPILOT_AUTH_SECRET=replace-with-32-plus-random-characters
QUANTPILOT_AUTH_SECURE_COOKIES=1
QUANTPILOT_SECURITY_HSTS=1
QUANTPILOT_AUTH_TRUSTED_ORIGINS=https://quantpilot.example.com
QUANTPILOT_AUTH_ALLOW_SIGNUP=0
QUANTPILOT_AUTH_REMEMBER_ME=0
QUANTPILOT_AUTH_AUDIT_RETENTION_DAYS=180
QUANTPILOT_AUTH_EXPIRED_RECORD_GRACE_SECONDS=3600

# Use --require-bootstrap only for the one-time administrator bootstrap. Remove
# both values from the long-running service environment after bootstrap.
QUANTPILOT_AUTH_ADMIN_EMAIL=admin@example.com
QUANTPILOT_AUTH_ADMIN_PASSWORD=replace-with-strong-bootstrap-password
QUANTPILOT_AUTH_ADMIN_NAME=QuantPilot 管理员

DATABASE_URL=postgresql://quantpilot:replace-with-database-password@timescaledb:5432/quantpilot?schema=public
REDIS_URL=redis://redis:6379/0
PROJECTS_DIR=/var/lib/quantpilot/projects
ENCRYPTION_KEY=replace-with-64-hex-characters

QUANTPILOT_DATABASE_ENABLED=1
QUANTPILOT_DATABASE_REQUIRED=1
QUANTPILOT_MARKET_API_ENABLED=1
QUANTPILOT_MARKET_API_REQUIRED=1
QUANTPILOT_MARKET_API_URL=http://market-data:8000
QUANTPILOT_MARKET_ADMIN_TOKEN=replace-with-32-plus-random-characters
QUANTPILOT_REDIS_CACHE_ENABLED=1
QUANTPILOT_REDIS_REQUIRED=1
QUANTPILOT_OBSERVABILITY_ENABLED=1
QUANTPILOT_OBSERVABILITY_REQUIRED=1

LOKI_URL=http://loki:3100
GRAFANA_ANONYMOUS_ENABLED=0
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password

DEEPSEEK_API_KEY=replace-with-production-deepseek-key
QUANTPILOT_ADMIN_TOKEN=replace-with-32-plus-random-characters
QUANTPILOT_ENABLE_INTERNAL_TOKEN_API=0
QUANTPILOT_INTERNAL_API_TOKEN=

QUANTPILOT_GENERATED_SANDBOX=1
QUANTPILOT_ALLOW_UNSANDBOXED_GENERATED_CODE=0

QUANTPILOT_REQUIRE_HIDDEN_EVAL=1
QUANTPILOT_REQUIRE_PRODUCTION_JUDGE_CALIBRATION=1
QUANTPILOT_REQUIRE_INDEPENDENT_JUDGE=1
QUANTPILOT_EVAL_DATASET_VISIBILITY=hidden
QUANTPILOT_REPLAY_HASH_KEY=replace-with-16-plus-random-characters
QUANTPILOT_HIDDEN_EVAL_CASES_PATH=/run/secrets/quantpilot-hidden-eval-cases.json
QUANTPILOT_EVAL_JUDGE_CALIBRATION_PATH=/run/secrets/quantpilot-judge-calibration.json
