{
  "name": "quantpilot",
  "version": "2.0.0",
  "description": "Quant-focused AI workflow builder powered by MoAgent and configurable model providers",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/dev/run-full.js",
    "dev:web": "node scripts/dev/run-web.js",
    "dev:market": "uv run --extra baostock --extra akshare --project services/market-data quantpilot-market-api",
    "dev:desktop": "node scripts/dev/run-desktop.js",
    "ensure:env": "node scripts/dev/setup-env.js",
    "clean:local": "node scripts/dev/cleanup-local-artifacts.js",
    "clean:local:dry-run": "node scripts/dev/cleanup-local-artifacts.js --dry-run",
    "clean:workspaces": "node scripts/dev/cleanup-local-artifacts.js --include-workspace-builds",
    "build": "node scripts/build/run-build.js",
    "build:standalone": "node scripts/build/run-build.js --standalone --turbopack",
    "build:desktop": "npm run build:standalone && electron-builder",
    "styles:build": "node scripts/build/build-stable-css.js",
    "brand:icons": "node scripts/build/generate-brand-icons.js",
    "package:mac": "npm run build:standalone && electron-builder --mac",
    "package:win": "npm run build:standalone && electron-builder --win",
    "package:linux": "npm run build:standalone && electron-builder --linux",
    "start": "next start",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:backend",
    "test:unit": "vitest run",
    "test:moagent:postgres": "node scripts/checks/run-moagent-postgres-integration.js",
    "test:backend": "uv run --project services/market-data pytest -q services/market-data/tests",
    "type-check": "node scripts/checks/type-check.js",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy && npm run auth:ensure-access-control",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "auth:bootstrap": "tsx scripts/auth/bootstrap-user.ts",
    "auth:enable-local": "node scripts/dev/setup-env.js --enable-auth",
    "auth:ensure-access-control": "tsx scripts/auth/ensure-access-control.ts",
    "auth:cleanup": "tsx scripts/auth/cleanup.ts",
    "auth:verify": "node scripts/auth/verify-user-management.js",
    "db:up": "docker compose up -d timescaledb redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f timescaledb redis",
    "obs:up": "docker compose up -d loki grafana alloy",
    "obs:down": "docker compose stop loki grafana alloy",
    "obs:logs": "docker compose logs -f loki grafana alloy",
    "redis:up": "docker compose up -d redis",
    "redis:logs": "docker compose logs -f redis",
    "redis:cli": "docker compose exec redis redis-cli",
    "db:psql": "docker compose exec timescaledb psql -U quantpilot -d quantpilot",
    "db:init": "node scripts/db/init-database.js",
    "db:doctor": "node scripts/db/check-database.js",
    "db:sync-workspaces": "node scripts/db/sync-projects-from-workspaces.js",
    "db:migrate-platform-state": "node scripts/db/migrate-platform-state-to-postgres.js",
    "db:backup:release": "node scripts/db/release-backup.js",
    "db:restore:release": "node scripts/db/release-restore.js",
    "market:maintain": "node scripts/ops/refresh-market-data.js",
    "market:maintain:dry-run": "node scripts/ops/refresh-market-data.js --dry-run",
    "worker:generation": "node --import tsx scripts/workers/generation-worker.ts",
    "worker:generation:once": "node --import tsx scripts/workers/generation-worker.ts --once",
    "setup": "npm install && prisma generate && npm run db:init",
    "check:models": "node scripts/checks/check-deepseek-runtime.js",
    "check:ai-provider-boundary": "node scripts/checks/check-ai-provider-boundary.js",
    "check:integrations": "node --env-file-if-exists=.env.local --import tsx scripts/checks/check-long-term-integrations.ts",
    "check:memory-production": "node --env-file-if-exists=.env.local --import tsx scripts/checks/check-memory-production-readiness.ts",
    "check:triad-experience": "node --env-file-if-exists=.env.local --import tsx scripts/checks/check-triad-experience.ts",
    "check:triad-experience:large": "node --env-file-if-exists=.env.local --import tsx scripts/checks/check-triad-experience.ts --scale=4",
    "check:memory-knowledge-50": "node --env-file-if-exists=.env.local --import tsx scripts/checks/check-memory-knowledge-50.ts",
    "check:task-e2e": "node --env-file-if-exists=.env.local --import tsx scripts/checks/check-task-e2e-campaign.ts",
    "check:production": "node scripts/checks/check-production-readiness.js",
    "check:standalone-runtime": "node scripts/checks/check-standalone-runtime.js",
    "doctor": "node scripts/checks/doctor.js",
    "doctor:full": "node scripts/checks/doctor.js --full",
    "check:skills": "node scripts/checks/check-skills-registry.js --check-lock && node scripts/checks/check-skill-scripts.js",
    "check:skills:metadata": "node scripts/checks/check-skills-registry.js",
    "check:skills:scripts": "node scripts/checks/check-skill-scripts.js",
    "package:skills": "node scripts/skills/package-skills.js",
    "check:validation-repair": "node scripts/checks/check-validation-repair.js",
    "check:validation-stale": "node scripts/checks/check-validation-stale-report.js",
    "check:generated-artifacts": "node scripts/checks/check-generated-artifact-policy.js",
    "check:backend-architecture": "node scripts/checks/check-backend-architecture.js",
    "check:module-boundaries": "node scripts/checks/check-module-boundaries.js",
    "check:service-catalog": "node scripts/checks/check-service-catalog.js",
    "check:docs": "node scripts/checks/check-doc-links.js",
    "check:github-workflows": "node scripts/checks/check-github-workflows.js",
    "check:scaffold-templates": "tsx scripts/build/validate-scaffold-templates.ts",
    "check:quant-guardrails": "node scripts/checks/check-quant-research-guardrails.js",
    "check:benchmark-coverage": "node scripts/checks/check-quant-benchmark-coverage.js",
    "check:eval-datasets": "node scripts/checks/check-eval-datasets.js",
    "check:eval-judge-calibration": "node scripts/checks/check-eval-judge-calibration.js",
    "check:eval-mutations": "node scripts/checks/check-eval-mutations.js --min-kill-rate 100",
    "check:eval-schedule": "node scripts/checks/check-eval-schedule.js",
    "eval:ci": "node scripts/checks/check-eval-ci-gate.js --mode contract",
    "eval:ci:e2e": "node scripts/checks/check-eval-ci-gate.js --mode e2e --max-age-hours 48",
    "eval:ci:hidden": "node scripts/checks/check-eval-ci-gate.js --mode e2e --dataset-visibility hidden --max-age-hours 48",
    "eval:ci:shadow": "node scripts/checks/check-eval-ci-gate.js --mode e2e --dataset-visibility production_replay --max-age-hours 48",
    "eval:prepare-shadow": "node scripts/evals/prepare-shadow-replay.js",
    "check:homepage": "node scripts/checks/check-homepage-visual.js",
    "check:market-freshness": "node scripts/checks/check-market-data-freshness.js",
    "check:project-visual": "node scripts/checks/check-project-visual.js",
    "check:platform-visuals": "node scripts/checks/check-platform-visuals.js",
    "check:eval-platform-visual": "node scripts/checks/check-eval-platform-visual.js",
    "check:business-knowledge-visual": "node scripts/checks/check-business-knowledge-visual.js",
    "check:ops-platform-visual": "node scripts/checks/check-ops-platform-visual.js",
    "check:research-reports-visual": "node scripts/checks/check-research-reports-visual.js",
    "check:skills-visual": "node scripts/checks/check-skills-visual.js",
    "security:audit": "npm audit --audit-level=high --registry=https://registry.npmjs.org",
    "security:audit:production": "npm audit --omit=dev --audit-level=high --registry=https://registry.npmjs.org",
    "release:check": "node scripts/checks/release-check.js",
    "release:check:full": "node scripts/checks/release-check.js --security --runtime",
    "release:check:production": "node scripts/checks/release-check.js --security --production",
    "release:check:evidence": "node scripts/checks/release-check.js --security --runtime --eval-contract --e2e-evidence",
    "benchmark:quant:contract": "node scripts/evals/run-quant-benchmarks.js --mode contract",
    "benchmark:quant:e2e": "node scripts/evals/run-quant-benchmarks.js --mode e2e",
    "benchmark:quant:hidden": "node scripts/evals/run-quant-benchmarks.js --mode e2e --dataset-visibility hidden",
    "benchmark:quant:shadow": "node scripts/evals/run-quant-benchmarks.js --mode e2e --dataset-visibility production_replay",
    "postinstall": "npm run ensure:env"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tar": "^7.5.20",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.5.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "brace-expansion@2.0.0 - 2.1.1": "2.1.2",
    "brace-expansion@3.0.0 - 5.0.6": "5.0.7",
    "hono": "^4.12.30",
    "postcss": "$postcss",
    "sharp": "0.35.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "ai",
    "deepseek",
    "app-builder",
    "nextjs",
    "code-generation",
    "no-code",
    "low-code"
  ],
  "author": "tiammomo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/tiammomo/QuantPilot.git"
  },
  "build": {
    "appId": "com.quantpilot.desktop",
    "productName": "QuantPilot",
    "files": [
      "index.js",
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/static",
        "to": ".next/static"
      },
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": ".moagent",
        "to": ".moagent"
      },
      {
        "from": "scripts/security",
        "to": "scripts/security"
      }
    ],
    "asar": true,
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
