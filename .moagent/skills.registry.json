{
  "schemaVersion": 1,
  "policy": {
    "targetCoreSkillCount": 12,
    "packageFormat": "tgz",
    "packageDir": ".moagent/skill-packages",
    "description": "QuantPilot Skills 仅使用已登记的规范 ID 和当前版本合同；非量化强相关能力不使用 quant 前缀，新增能力优先并入核心 Skill。"
  },
  "coreSkills": [
    {
      "id": "run-planner",
      "name": "运行规划",
      "version": "0.4.0",
      "status": "stable",
      "scope": "workflow",
      "boundary": "解释平台生成的通用任务、领域计划和澄清门禁，指导后续执行；不生成或改写平台控制产物。",
      "inputs": [
        "用户问题",
        ".data-agent/workspace.json",
        ".data-agent/profile.json",
        ".data-agent/task.json",
        ".data-agent/plan.json",
        ".data-agent/finance-query-rewrite.json",
        "当前或上一轮 .data-agent/finance-run-plan.json"
      ],
      "outputs": [
        "意图完整性结果",
        "可执行事实、真实缺口与下一步指引"
      ],
      "scripts": [
        "scripts/intent_clarifier.py"
      ],
      "validation": [
        "不清晰任务必须停在 needs_clarification",
        "清晰任务必须进入 planned",
        "可解析的证券名称不得仅因缺少代码而追问",
        "最近怎么样等泛化诊断必须使用默认范围继续",
        "无新标的的页面修订必须继承上一轮 symbols/timeRange/template",
        "平台附加执行说明不得参与能力或模板判断"
      ],
      "references": [
        "references/run-plan-contract.md"
      ]
    },
    {
      "id": "query-rewrite",
      "name": "问题改写",
      "version": "0.5.0",
      "status": "stable",
      "scope": "workflow",
      "boundary": "作为规划前唯一语义事实源，由所选 LLM 通过严格 Schema 解析全部自然语言语义，再经原文字面证据、独立标的 Resolver 与确定性安全策略核验；模型不可用时失败关闭。",
      "inputs": [
        "用户原始问题",
        "用户选定的 ModelPort 或直连 LLM",
        ".data-agent/workspace.json.runtime 与 Finance Run Plan 无密钥 LLM profile",
        "后端 GET /api/v1/symbols/resolve",
        "用户选择的 capabilityId"
      ],
      "outputs": [
        ".data-agent/finance-query-rewrite.json",
        "resolvedSymbols",
        "timeRange",
        "analysisFocus",
        "clarification issues",
        "execution strategy/LLM trace",
        "deterministic safety decision"
      ],
      "endpoints": [
        "POST /api/quant/query/rewrite",
        "GET /api/v1/symbols/resolve"
      ],
      "scripts": [
        "scripts/validate_query_rewrite.py"
      ],
      "references": [
        "references/query-rewrite-contract.md"
      ],
      "validation": [
        "问题改写必须先于 run plan 和数据预取",
        "preview 与 execution 都必须调用所选 LLM，不存在关键词语义改写旁路",
        "LLM 未配置、超时、失败或输出无效时必须返回 llm_unavailable 并停止下游执行",
        "LLM 只能拆语义，不得发明或确认证券代码",
        "resolvedSymbols 必须使用标准六位代码且不得重复",
        "前端、规划器、预取器和 Skills 必须消费同一契约",
        "标的未找到、标的歧义和解析服务不可用必须使用不同错误码",
        "确定性收益承诺必须返回 refused，禁止进入取数和 Agent 执行",
        "Run Plan 不得脱离 Query Rewrite 重新猜测标的、周期或分析重点",
        "数据预取只能消费 run_plan.symbols，不得从原始问题二次解析证券名称"
      ]
    },
    {
      "id": "quant-data-registry",
      "name": "数据注册与信源选择",
      "version": "0.5.0",
      "status": "stable",
      "scope": "quant",
      "boundary": "查询后端数据能力、本地 TimescaleDB 覆盖、候选信源、缓存、主备源、字段补数和降级规则。",
      "inputs": [
        ".data-agent/finance-run-plan.json",
        "后端 /api/v1/registry",
        "后端 /api/v1/research/universes/summary",
        "后端 /api/v1/research/universes/{universe_id}/members",
        "后端 /api/v1/research/data-coverage",
        "后端 /api/v1/provider-candidates",
        "docs/market-data-source-knowledge.md"
      ],
      "outputs": [
        "本地覆盖说明",
        "数据源选择说明",
        "候选源限制说明",
        "字段补数计划"
      ],
      "validation": [
        "必须先说明本地库覆盖、source/provider、as_of、fetched_at 和 data_quality",
        "历史 K 线补数必须说明字段来源和 provider 边界",
        "本地库已有覆盖时不得优先调用外部历史接口"
      ],
      "scripts": [
        "scripts/select_data_route.py"
      ],
      "references": [
        "references/registry-routing-contract.md"
      ]
    },
    {
      "id": "quant-symbol-resolver",
      "name": "标的解析",
      "version": "0.3.0",
      "status": "stable",
      "scope": "quant",
      "boundary": "把中文简称、代码、指数、ETF 转为标准证券代码、市场和资产类型。",
      "inputs": [
        "用户问题",
        "候选标的文本"
      ],
      "outputs": [
        "symbols",
        "resolvedSymbols"
      ],
      "validation": [
        "finance-run-plan.symbols 必须是代码字符串数组",
        "同名 A 股唯一时必须自动选择并继续",
        "只有多个同优先级候选时才允许追问"
      ],
      "scripts": [
        "scripts/rank_candidates.py"
      ],
      "references": [
        "references/symbol-resolution-contract.md"
      ]
    },
    {
      "id": "image-extraction",
      "name": "图片提取",
      "version": "0.3.0",
      "status": "stable",
      "scope": "input",
      "boundary": "读取用户上传的图片附件清单，校验图片文件，抽取或标注持仓截图中的资产、股票、成本、盈亏、现金和仓位字段。",
      "inputs": [
        ".data-agent/attachments.json",
        "uploaded images",
        "用户问题"
      ],
      "outputs": [
        "evidence/image_extraction.json",
        "dashboard-data.json.imageExtraction"
      ],
      "endpoints": [
        "mcp__QuantPilotImage__quant_extract_uploaded_image",
        "mcp__MiniMax__understand_image"
      ],
      "validation": [
        "图片任务必须先调用 image-extraction",
        "无法识别的截图字段必须写 null 并列入 needs_manual_confirmation",
        "不得编造截图中的持仓、成本、现金或盈亏"
      ],
      "scripts": [
        "scripts/normalize_extraction.py"
      ],
      "references": [
        "references/portfolio-image-contract.md"
      ]
    },
    {
      "id": "quant-market-data",
      "name": "行情数据",
      "version": "0.5.1",
      "status": "stable",
      "scope": "quant",
      "boundary": "本地 TimescaleDB K 线、实时行情、指数/ETF、批量行情、多源 fallback 和本地字段补数。",
      "inputs": [
        "symbols",
        "timeRange",
        "period",
        "adjustment"
      ],
      "outputs": [
        "local_coverage",
        "quote",
        "kline.bars",
        "assets[]",
        "field_enrichment"
      ],
      "endpoints": [
        "GET /api/v1/analysis/context/{symbol}",
        "GET /api/v1/research/universes/summary",
        "GET /api/v1/research/data-coverage",
        "GET /api/v1/research/universes/{universe_id}/members",
        "GET /api/v1/research/bars/{symbol}",
        "GET /api/v1/quotes/realtime/{symbol}",
        "POST /api/v1/quotes/realtime",
        "GET /api/v1/quotes/history/{symbol}",
        "POST /api/v1/ingestion/baostock/history",
        "POST /api/v1/ingestion/akshare/history",
        "GET /api/v1/provider-candidates"
      ],
      "validation": [
        "趋势类任务必须优先读取 /api/v1/research/bars/{symbol}",
        "趋势类任务必须有 K 线或明确的 K 线错误面板",
        "成交额、换手率和振幅缺失时必须说明补数状态"
      ],
      "scripts": [
        "scripts/validate_market_bars.py"
      ],
      "references": [
        "references/market-data-contract.md"
      ]
    },
    {
      "id": "quant-fundamentals",
      "name": "基本面与事件",
      "version": "0.3.0",
      "status": "stable",
      "scope": "quant",
      "boundary": "财务报表、财务衍生指标、公告和事件上下文。",
      "inputs": [
        "symbols",
        "reportPeriods"
      ],
      "endpoints": [
        "GET /api/v1/fundamentals/financials/{symbol}",
        "GET /api/v1/indicators/fundamental/{symbol}",
        "GET /api/v1/events/announcements/{symbol}"
      ],
      "outputs": [
        "financials",
        "fundamentalIndicators",
        "announcements",
        "valuation"
      ],
      "scripts": [
        "scripts/valuation_scenarios.py"
      ],
      "validation": [
        "必须说明报告期、缺失字段和数据来源",
        "经营现金流与净利润增速必须使用同一报告期和正式 API 字段",
        "估值情景必须展示假设、缺失字段和非投资建议限制"
      ],
      "references": [
        "references/fundamentals-contract.md"
      ]
    },
    {
      "id": "quant-indicators",
      "name": "指标计算",
      "version": "0.3.0",
      "status": "stable",
      "scope": "quant",
      "boundary": "技术指标、收益、波动、最大回撤、成交量、相关性、流动性和风险指标计算。",
      "inputs": [
        "kline.bars",
        "assets[]"
      ],
      "outputs": [
        "technicalIndicators",
        "computedMetrics",
        "riskMetrics",
        "correlation",
        "liquidity",
        "trendTemplate"
      ],
      "endpoints": [
        "GET /api/v1/indicators/technical/{symbol}"
      ],
      "scripts": [
        "scripts/correlation.py",
        "scripts/liquidity.py",
        "scripts/trend_template.py"
      ],
      "validation": [
        "必须明确样本长度和计算口径",
        "多标的任务必须计算相关性或说明样本不足",
        "流动性摘要必须说明成交额窗口和代理口径",
        "调仓/趋势任务必须输出趋势模板或说明样本不足"
      ],
      "references": [
        "references/technical-risk-methodology.md"
      ]
    },
    {
      "id": "quant-backtest",
      "name": "回测复盘",
      "version": "0.3.0",
      "status": "stable",
      "scope": "quant",
      "boundary": "基于本地 TimescaleDB K 线的策略参数、回测执行、净值曲线、回撤、交易明细和限制说明。",
      "inputs": [
        "symbols",
        "strategyParams",
        "local kline.bars"
      ],
      "outputs": [
        "backtest",
        "trades",
        "equityCurve",
        "localBarsCoverage"
      ],
      "endpoints": [
        "GET /api/v1/research/bars/{symbol}",
        "GET /api/v1/backtests/ma-crossover/{symbol}"
      ],
      "validation": [
        "必须先确认本地 bars 覆盖",
        "必须说明费用、样本、滑点和策略限制"
      ],
      "scripts": [
        "scripts/validate_backtest.py"
      ],
      "references": [
        "references/backtest-contract.md"
      ]
    },
    {
      "id": "data-quality",
      "name": "数据质量",
      "version": "0.4.0",
      "status": "stable",
      "scope": "evidence",
      "boundary": "证据文件、来源、时效、缺失字段、异常值和限制说明。",
      "inputs": [
        "raw data",
        "dashboard-data.json",
        ".data-agent/finance-run-plan.json"
      ],
      "outputs": [
        "evidence/sources.json",
        "evidence/data_quality.json"
      ],
      "validation": [
        "每个展示数据必须可追溯到 source"
      ],
      "scripts": [
        "scripts/assess_data_quality.py"
      ],
      "references": [
        "references/evidence-contract.md"
      ]
    },
    {
      "id": "platform-ui-product-design",
      "name": "平台 UI 产品设计",
      "version": "0.3.0",
      "status": "stable",
      "scope": "platform",
      "boundary": "QuantPilot 主平台页面、组件、控制台、设置、列表、导航、状态和响应式体验设计，不负责生成工作空间金融看板。",
      "inputs": [
        "src/app 页面",
        "src/components 组件",
        "docs/ui-shadcn-migration.md",
        "现有设计 token"
      ],
      "outputs": [
        "平台 React/Tailwind UI",
        "可复用组件",
        "页面状态和响应式布局"
      ],
      "validation": [
        "必须复用现有 UI/quant primitives",
        "必须覆盖 loading/empty/error/disabled/long text 状态",
        "必须通过 lint 和 type-check"
      ],
      "scripts": [
        "scripts/validate_state_matrix.py"
      ],
      "references": [
        "references/ui-ux-pro-max-adapter.md",
        "references/platform-ui-contract.md"
      ]
    },
    {
      "id": "dashboard-visualization",
      "name": "可视化看板",
      "version": "0.6.0",
      "status": "stable",
      "scope": "visualization",
      "boundary": "基于已验证 final 数据、MoAgent 定向注入的模板与金融指标判读生成 Next.js 金融分析看板；验证失败时只按平台报告修复允许产物，提交后由平台负责 build、preview 和 validation。",
      "inputs": [
        "data_file/final/dashboard-data.json",
        "evidence",
        ".data-agent/finance-run-plan.json",
        ".data-agent/validation.json",
        ".data-agent/validation-repair-plan.json",
        ".data-agent/visual-validation.json"
      ],
      "outputs": [
        "app/page.tsx",
        "app/globals.css",
        "visualization.template_id",
        "visualization.variant_id"
      ],
      "validation": [
        "页面必须绑定真实数据",
        "生成前必须按 visual_judgement 判读时间/维度/指标字段和指标口径",
        "首屏必须呈现真实金融内容和核心图表/矩阵",
        "多标的任务不得降级成单股模板",
        "用户要求累计收益曲线时必须绘制带日期轴和统一尺度的折线图",
        "用户要求相关性矩阵时必须绘制真实矩阵/热力图",
        "未明确要求时不得新增交易计划、买卖点、止损或目标价",
        "迷你 sparkline 不能替代主图或对比矩阵",
        "缺数据时不得散落占位符，必须呈现专业待接入/待确认空态",
        "移动端不得出现页面级横向溢出",
        "页面必须使用连续金融工作台画布，禁止独立圆角卡片网格、悬浮阴影和 card 套 card",
        "指标带必须说明时间窗口、覆盖对象和计算口径，不能裸写内部公式",
        "指标带必须按指标数量均衡分栏，禁止桌面端 N+1 孤项、大面积空白和数值拆行",
        "渠道端点、技术证据、模板名称和必备组件状态不得作为用户可见分区",
        "必须包含图表、数据时间/质量、加载/错误/空状态，后台 evidence 保留来源",
        "必须按 visualization.templateId 选择模板族，并按 visualization.variantId/layout 覆盖具体页面结构",
        "动态 JSON 的每一层嵌套对象都必须分别使用 asRecord 守卫并通过 Next.js build",
        "自动验证失败时必须按 failure ID 和文件指针定向读取报告并实际修复",
        "最终数据形态失败必须修复 dashboard-data.json 标准契约和页面绑定",
        ".data-agent 全目录只读，Agent 不得改写计划、状态、事件或验证报告",
        "不得顺序全量读取工作空间、run plan 或 references，优先消费 Task Packet、skill capsule 和 initial dashboard contract",
        "Agent 调用 submit_result 后必须停止，build、preview 和 validation 统一由平台执行",
        "不得引用外部 CDN/远程资源、不得保留 mock/static 数据、不得写入明文密钥"
      ],
      "scripts": [
        "scripts/validate_dashboard_contract.py"
      ],
      "references": [
        "references/scenario_templates.md",
        "references/visual_judgement.md",
        "references/dashboard-data-contract.md"
      ]
    }
  ]
}
