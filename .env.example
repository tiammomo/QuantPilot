# QuantPilot complete environment reference
# ==========================================
# This committed file documents supported variables and safe development defaults.
# Do not put real credentials here and do not use it as a production secret file.
#
# File responsibilities and precedence:
#   1. Existing process/container variables win over every file.
#   2. .env.local contains ignored credentials and machine-specific overrides.
#   3. .env contains ignored, generated local infrastructure defaults.
#   4. .env.example is documentation; .env.production.example is a strict template.
#
# Recommended first start:
#   npm install                 # postinstall also runs npm run ensure:env
#   npm run ensure:env          # creates/updates .env and .env.local safely
#   # Add only the credentials for your chosen mode to .env.local.
#   npm run db:up && npm run db:init
#   npm run dev
#
# Supported model modes:
#   A. Recommended: MODELPORT_API_KEY; Qwen is default, DeepSeek is optional via ModelPort.
#   B. Direct DeepSeek: DEEPSEEK_API_KEY in .env.local/process secrets, then explicitly
#      select model `deepseek-v4-flash`; the global default remains ModelPort Qwen.
#   C. Qwen-only: MODELPORT_API_KEY scoped only to local_qwen; no DeepSeek key is needed.
#
# Memory is independent of the model provider. Set QUANTPILOT_MEMORY_ENABLED=0 to run
# normally without evolvable-user-memory. Do not use offline mode merely to disable Memory.
# Full examples and effect matrices: docs/configuration.md

# Database / local infrastructure
# Docker Compose uses the POSTGRES_*, Redis, and ClickHouse values below. DATABASE_URL is
# used by Next.js/Prisma. Change both sides together when changing host ports or credentials.
DATABASE_URL="postgresql://quantpilot:quantpilot_dev_password@127.0.0.1:35433/quantpilot?schema=public"
TIMESCALEDB_IMAGE="timescale/timescaledb:2.27.1-pg18"
POSTGRES_DB="quantpilot"
POSTGRES_USER="quantpilot"
POSTGRES_PASSWORD="quantpilot_dev_password"
POSTGRES_PORT=35433
REDIS_URL="redis://127.0.0.1:36380/0"
REDIS_IMAGE="redis:8-alpine"
REDIS_PORT=36380
REDIS_NAMESPACE="quantpilot"
CLICKHOUSE_IMAGE="clickhouse/clickhouse-server:25.8"
CLICKHOUSE_DB="quantpilot"
CLICKHOUSE_USER="quantpilot"
CLICKHOUSE_PASSWORD="quantpilot_dev_password"
CLICKHOUSE_HTTP_PORT=38123
CLICKHOUSE_NATIVE_PORT=39023
CLICKHOUSE_URL="http://127.0.0.1:38123"
PROJECTS_DIR="./data/projects"
ENCRYPTION_KEY="replace-with-a-64-character-hex-secret"
QUANTPILOT_ENABLE_INTERNAL_TOKEN_API=0
QUANTPILOT_INTERNAL_API_TOKEN=""
# Protects host-level mutation APIs such as Skills publishing and evaluation runs.
# Local loopback development may leave it empty; production/strict mode fails closed.
QUANTPILOT_ADMIN_TOKEN=""
QUANTPILOT_MAX_IMAGE_UPLOAD_BYTES=10485760
QUANTPILOT_ALLOW_SKILLS_REGISTRY_FALLBACK=0

# Component availability and degradation
# auto: optional components can be missing; strict: required components fail health checks;
# offline: skip optional external probes and use file/static fallbacks.
# Prefer a component's ENABLED=0 switch when only that component should be disabled.
QUANTPILOT_DEGRADATION_MODE="auto"
QUANTPILOT_DATABASE_ENABLED=1
QUANTPILOT_DATABASE_REQUIRED=1
QUANTPILOT_MARKET_API_ENABLED=1
QUANTPILOT_MARKET_API_REQUIRED=0
QUANTPILOT_MEMORY_ENABLED=1
# REQUIRED=0 means "degrade if unavailable", not "disabled". To make zero Memory requests,
# set ENABLED=0. With ENABLED=0, the Memory URL/token/broker values may remain empty.
QUANTPILOT_MEMORY_REQUIRED=0
# 生产默认要求服务声明 production_ready=true；开发环境可保持 0 联调未完成治理的实例。
QUANTPILOT_MEMORY_REQUIRE_PRODUCTION_READY=0
QUANTPILOT_MEMORY_API_URL="http://127.0.0.1:38089"
# Hard application/consumer isolation boundary in Memory. Do not use a common
# tenant across independent products. QuantPilot workspaces remain separated by
# the server-owned context.project_id facet and a consumer-side projection fence.
QUANTPILOT_MEMORY_TENANT_ID="quantpilot-local"
QUANTPILOT_MEMORY_TIMEOUT_MS=5000
QUANTPILOT_MEMORY_RECALL_LIMIT=6
QUANTPILOT_MEMORY_MAX_CONTEXT_CHARACTERS=2000
# 仅供本地 development 或单 subject 调试；多用户生产禁止静态 token。
QUANTPILOT_MEMORY_BEARER_TOKEN=""
# 多用户生产必须通过可信 broker 按 tenant/subject/purpose 换取短期 JWT，禁止静态通配 token。
QUANTPILOT_MEMORY_TOKEN_BROKER_URL=""
QUANTPILOT_MEMORY_TOKEN_BROKER_CLIENT_ID=""
QUANTPILOT_MEMORY_TOKEN_BROKER_CLIENT_SECRET=""
QUANTPILOT_MEMORY_TOKEN_AUDIENCE="evolvable-memory-api"
# Non-human subject with an active personalization ProcessingGrant. Used only
# by check:memory-production; the command logs a count, never preference content.
QUANTPILOT_MEMORY_PRODUCTION_PROBE_SUBJECT_ID=""
QUANTPILOT_CLICKHOUSE_ENABLED=0
QUANTPILOT_CLICKHOUSE_REQUIRED=0
QUANTPILOT_OBSERVABILITY_ENABLED=1
QUANTPILOT_OBSERVABILITY_REQUIRED=0
QUANTPILOT_REDIS_REQUIRED=0

# Observability / local logs
# OBSERVABILITY_ENABLED=0 is supported. Otherwise Loki is queried first and local runtime
# log files remain the fallback when REQUIRED=0.
LOKI_IMAGE="grafana/loki:3.6.0"
LOKI_PORT=33100
LOKI_URL="http://127.0.0.1:33100"
LOKI_QUERY='{app="quantpilot"}'
GRAFANA_IMAGE="grafana/grafana:13.0.1"
GRAFANA_PORT=33012
GRAFANA_URL="http://127.0.0.1:33012"
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD="quantpilot_dev_password"
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ALLOY_IMAGE="grafana/alloy:v1.16.1"
GRAFANA_ALLOY_PORT=33145

# Web app and generated-preview port pools
QUANTPILOT_WEB_HOST="127.0.0.1"
PORT=3000
WEB_PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PREVIEW_PORT_START=4100
PREVIEW_PORT_END=4999

# Project login. "disabled" preserves the existing local single-user workflow.
# To enable it, switch to "local", generate a 32+ character secret, deploy the
# auth migration, and run `npm run auth:bootstrap` once.
QUANTPILOT_AUTH_MODE="disabled"
QUANTPILOT_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
QUANTPILOT_AUTH_SECURE_COOKIES=0
# Enable only behind an HTTPS production origin. This is enforced by the
# production readiness gate and becomes a build-time security header.
QUANTPILOT_SECURITY_HSTS=0
QUANTPILOT_AUTH_TRUSTED_ORIGINS="http://localhost:3000"
QUANTPILOT_AUTH_ALLOW_SIGNUP=0
QUANTPILOT_AUTH_SESSION_EXPIRES_SECONDS=43200
QUANTPILOT_AUTH_SESSION_UPDATE_AGE_SECONDS=300
QUANTPILOT_AUTH_SESSION_FRESH_AGE_SECONDS=1800
QUANTPILOT_AUTH_REMEMBER_ME=0
# `npm run auth:cleanup` keeps security events for this many days and gives
# expired session/verification records a short grace period before deletion.
QUANTPILOT_AUTH_AUDIT_RETENTION_DAYS=180
QUANTPILOT_AUTH_EXPIRED_RECORD_GRACE_SECONDS=3600
# Bootstrap values are read only by `npm run auth:bootstrap`. When email and
# password are empty on localhost development, the command keeps admin / admin without
# requiring a first-login password change. Production,
# strict mode and non-localhost deployments require explicit strong credentials.
QUANTPILOT_AUTH_ADMIN_EMAIL=""
QUANTPILOT_AUTH_ADMIN_PASSWORD=""
QUANTPILOT_AUTH_ADMIN_NAME="QuantPilot 管理员"

# Market data backend
# Set MARKET_API_ENABLED=0 for UI/Agent work that does not need live market capabilities.
# REQUIRED=0 permits graceful degradation; it does not disable requests while healthy.
QUANTPILOT_MARKET_HOST="127.0.0.1"
QUANTPILOT_MARKET_PORT=8000
QUANTPILOT_MARKET_API_URL="http://127.0.0.1:8000"
# Required for all write endpoints in strict mode or when binding to a non-loopback host.
# When configured, it is also required for loopback requests (Bearer or X-QuantPilot-Admin-Token).
QUANTPILOT_MARKET_ADMIN_TOKEN=""
QUANTPILOT_REDIS_CACHE_ENABLED=1
QUANTPILOT_SCREENER_CACHE_TTL_SECONDS=60
QUANTPILOT_SCREENER_PREFETCH_TIMEOUT_MS=45000
# Daily maintenance is run by deploy/systemd/quantpilot-market-maintenance.timer.
# The command remains explicit in development: npm run market:maintain[:dry-run].
QUANTPILOT_MARKET_MAINTENANCE_ENABLED=0
QUANTPILOT_MARKET_MAINTENANCE_UNIVERSE_ID="a-share-sample-research-pool"
QUANTPILOT_MARKET_CALENDAR_LOOKBACK_DAYS=30
QUANTPILOT_MARKET_HISTORY_LOOKBACK_DAYS=14
QUANTPILOT_MARKET_MAINTENANCE_REQUEST_DELAY_SECONDS=0.2
QUANTPILOT_MARKET_MAINTENANCE_BATCH_DELAY_SECONDS=0.7
QUANTPILOT_MARKET_MAINTENANCE_BATCH_SIZE=25
QUANTPILOT_MARKET_MAINTENANCE_MAX_RETRIES=3
QUANTPILOT_MARKET_MAINTENANCE_POLL_INTERVAL_MS=2000
QUANTPILOT_MARKET_CALENDAR_TIMEOUT_MS=120000
QUANTPILOT_MARKET_INGESTION_TIMEOUT_MS=1800000
QUANTPILOT_MARKET_FRESHNESS_MIN_SYMBOLS=250

# Research report notification webhooks
# Leave empty to keep notification deliveries in dry-run / failed-config mode.
QUANTPILOT_WXWORK_RESEARCH_WEBHOOK=""
QUANTPILOT_FEISHU_RESEARCH_WEBHOOK=""
QUANTPILOT_DINGTALK_RESEARCH_WEBHOOK=""
QUANTPILOT_DISCORD_RESEARCH_WEBHOOK=""

# Model providers
# Versioned provider/model/baseUrl profiles are locked in config/llm.json; browser/project
# input cannot inject an arbitrary provider URL. Qwen remains the default profile.
# This is a ModelPort CLIENT key, not a Qwen/DeepSeek upstream Provider key.
MODELPORT_API_KEY="replace-with-your-modelport-client-api-key"
QUANTPILOT_MODELPORT_URL="http://127.0.0.1:38082"
QUANTPILOT_MODELPORT_ENABLED=1
QUANTPILOT_MODELPORT_REQUIRED=0
# Every ModelPort client key is bound by a ModelPort admin to exactly this
# organization/project/environment tuple. Request headers only assert that
# binding and can never select a different tenant. Give every consuming
# application its own project ID and key; do not share QuantPilot's key.
QUANTPILOT_MODELPORT_ORGANIZATION_ID="org_local"
QUANTPILOT_MODELPORT_PROJECT_ID="prj_quantpilot"
QUANTPILOT_MODELPORT_ENVIRONMENT_ID="env_development"

# Stable consumer namespace shared by local integration evidence. This is the
# application boundary, while the database Project.id remains the workspace
# boundary. Other products must use their own consumer and Memory tenant IDs.
QUANTPILOT_INTEGRATION_CONSUMER_ID="quantpilot"

# Independent governed knowledge service. QuantPilot only uses the public AKEP
# HTTP contract; it never imports provider code or reads the provider database.
QUANTPILOT_KNOWLEDGE_ENABLED=1
QUANTPILOT_KNOWLEDGE_REQUIRED=0
QUANTPILOT_KNOWLEDGE_API_URL="http://localhost:33005"
QUANTPILOT_KNOWLEDGE_PURPOSE="quant-research"
QUANTPILOT_KNOWLEDGE_SPACES="https://knowledge.local/spaces/default"
# Query shared Spaces plus one deterministic workspace Space:
# <base>/<url-encoded trusted Project.id>. Disable only for a deliberately
# shared-only deployment. Production OAuth scopes must authorize both sets.
QUANTPILOT_KNOWLEDGE_PROJECT_SPACES_ENABLED=1
QUANTPILOT_KNOWLEDGE_PROJECT_SPACE_BASE_URL="https://knowledge.local/spaces/quantpilot/projects"
QUANTPILOT_KNOWLEDGE_TIMEOUT_MS=2000
QUANTPILOT_KNOWLEDGE_MAX_CONTEXT_CHARACTERS=8000
# Local development only. Production rejects static bearer tokens and requires OAuth.
QUANTPILOT_KNOWLEDGE_BEARER_TOKEN="dev-reader"
QUANTPILOT_KNOWLEDGE_OAUTH_TOKEN_URL=""
QUANTPILOT_KNOWLEDGE_OAUTH_CLIENT_ID=""
QUANTPILOT_KNOWLEDGE_OAUTH_CLIENT_SECRET=""
QUANTPILOT_KNOWLEDGE_OAUTH_RESOURCE=""
QUANTPILOT_KNOWLEDGE_OAUTH_SCOPE="akep:query akep:read akep:feedback"
# Official direct mode is optional. Uncomment only in ignored .env.local for local testing,
# or inject it with a deployment secret manager. Never copy ModelPort's
# DEEPSEEK_ANTHROPIC_AUTH_TOKEN into QuantPilot.
# DEEPSEEK_API_KEY="replace-with-your-official-deepseek-api-key"
# Project-visible LLM switches. Provider/model/baseUrl remain locked per profile.
# AGENT_ENABLED=0 disables model-backed Agent execution. Keep it enabled for workspace
# generation; this switch is not a provider fallback mechanism.
QUANTPILOT_LLM_AGENT_ENABLED=1
QUANTPILOT_LLM_QUERY_REWRITE_ENABLED=1

# Evaluation assurance. Keep hidden/replay datasets and HMAC keys outside the repository.
QUANTPILOT_EVAL_DATASET_VISIBILITY=public
QUANTPILOT_EVAL_CASES_PATH=
QUANTPILOT_HIDDEN_EVAL_CASES_PATH=
QUANTPILOT_PRODUCTION_REPLAY_CASES_PATH=
QUANTPILOT_REPLAY_HASH_KEY=
QUANTPILOT_REQUIRE_HIDDEN_EVAL=0
QUANTPILOT_EVAL_JUDGE_CALIBRATION_PATH=
QUANTPILOT_REQUIRE_PRODUCTION_JUDGE_CALIBRATION=0
QUANTPILOT_REQUIRE_INDEPENDENT_JUDGE=0

# Task-level E2E campaign. Unlike the service-level triad suite, this creates
# retained [E2E ...] Projects through the authenticated HTTP entry point and
# waits for Mission acceptance, Workspace validation and a live preview.
# Keep the password in ignored .env.local or a secret manager. admin/admin is
# accepted only against localhost for a freshly bootstrapped development node.
QUANTPILOT_TASK_E2E_BASE_URL="http://127.0.0.1:3000"
QUANTPILOT_TASK_E2E_ADMIN_LOGIN="admin"
QUANTPILOT_TASK_E2E_ADMIN_PASSWORD=""
QUANTPILOT_TASK_E2E_TIMEOUT_MS=1200000

# Query Rewrite is LLM-first for both preview and execution. Disabling it makes quantitative
# planning fail closed; there is no keyword-matching fallback.
QUANTPILOT_QUERY_REWRITE_LLM_TIMEOUT_MS=15000
QUANTPILOT_QUERY_REWRITE_LLM_MAX_RETRIES=0
# Qwen only: retry an invalid forced-tool payload at most twice. This still
# invokes the LLM and never falls back to keyword/regex semantic matching.
QUANTPILOT_QUERY_REWRITE_LLM_INVALID_OUTPUT_RETRIES=2
MOAGENT_MAX_REQUEST_BYTES=2000000
MOAGENT_TOOL_OUTPUT_CHARS=6000
MOAGENT_PROVIDER_MAX_RETRIES=2
MOAGENT_PROVIDER_RETRY_BASE_MS=500
MOAGENT_PROVIDER_RETRY_MAX_MS=10000
MOAGENT_MAX_TURNS=12
# Hard ceiling across one run. Typed/anchored inspection should normally finish well below this.
MOAGENT_MAX_TOTAL_TOOL_CALLS=20
# Trigger a request-local convergence directive before exploration dominates cost.
MOAGENT_PRE_WRITE_READ_ONLY_TURNS=3
MOAGENT_POST_WRITE_READ_ONLY_TURNS=2
# Provider output cap for one model turn.
MOAGENT_MAX_TURN_OUTPUT_TOKENS=12000
# Cumulative output-token budget across one complete MoAgent run.
MOAGENT_MAX_RUN_OUTPUT_TOKENS=24000
MOAGENT_CONTEXT_WINDOW_TOKENS=128000
# Keep a bounded working set instead of replaying every historical tool body each turn.
MOAGENT_MAX_INPUT_TOKENS=48000
# Calibrated cumulative provider-reported cost ceilings. Crossing one stops the next turn.
MOAGENT_MAX_RUN_INPUT_TOKENS=160000
# Optional stricter override; PhaseGraph already supplies a lane-specific default.
# MOAGENT_MAX_RUN_CACHE_MISS_INPUT_TOKENS=60000
MOAGENT_TIMEOUT_MS=1200000
MOAGENT_LEASE_TTL_MS=60000
MOAGENT_HEARTBEAT_INTERVAL_MS=15000
# Product-level Mission validation/evidence lease. This is independent from an
# individual AgentRun lease because build, preview and evidence verification can
# continue after the model run has submitted its candidate. The heartbeat must
# be smaller than the TTL. An expired verifier can be taken over; its old
# fencing token can no longer commit evidence or complete the Mission.
MOAGENT_MISSION_VERIFICATION_LEASE_TTL_MS=120000
MOAGENT_MISSION_VERIFICATION_HEARTBEAT_INTERVAL_MS=30000
# Project-level outer orchestration lease. It serializes planning/data-prefetch,
# Agent execution and manual validation across Web/worker processes. This lease
# is independent from AgentRun and Mission verification leases. PostgreSQL time
# is authoritative and the heartbeat must remain smaller than the TTL.
MOAGENT_GENERATION_LEASE_TTL_MS=120000
MOAGENT_GENERATION_HEARTBEAT_INTERVAL_MS=30000
# PostgreSQL durable dispatch worker lease. The job/outbox is authoritative;
# .quantpilot/generation-queue.json is a disposable projection. Expiry closes
# the old attempt as replan_required only after finer-grained leases are dead.
MOAGENT_DISPATCH_LEASE_TTL_MS=120000
MOAGENT_DISPATCH_HEARTBEAT_INTERVAL_MS=30000
# inline keeps local development single-process. Production must use worker and
# run deploy/systemd/quantpilot-generation-worker.service.
MOAGENT_DISPATCH_MODE=inline
MOAGENT_WORKER_POLL_INTERVAL_MS=1000
MOAGENT_WORKER_CONCURRENCY=1
MOAGENT_WORKER_CLAIM_BATCH_SIZE=20
MOAGENT_DISPATCH_RETRY_BASE_DELAY_MS=5000
# A persisted pending/retry_wait job older than this, with no live finer-grained
# lease, is an orphaned enqueue/claim crash window and is closed for replan.
MOAGENT_DISPATCH_PENDING_ORPHAN_GRACE_MS=120000
# Provider-neutral execution envelope limit (1024..4194304). Credential-shaped
# fields are rejected regardless of this value.
MOAGENT_DISPATCH_ENVELOPE_MAX_BYTES=262144
# Maximum startup/final-commit wait for the fail-closed workspace resource lock.
MOAGENT_RESOURCE_LOCK_WAIT_MS=5000
# Stable pod/host identifier written to lock owner metadata; defaults to hostname:pid.
MOAGENT_INSTANCE_ID=
# Instances jointly executing one project must share PostgreSQL, namespace, and filesystem.
MOAGENT_WORKSPACE_NAMESPACE=quantpilot-local
# Runtime capsules are atomic: compilation fails instead of truncating required steps/resources.
MOAGENT_SKILL_CONTEXT_CHARS=6000
MOAGENT_PREFETCHED_SKILL_CONTEXT_CHARS=4000
# Optional phase override: low, medium, high, or max. Empty uses medium for UI and high for data/repair.
MOAGENT_REASONING_EFFORT=
MOAGENT_REASONING=1

# Generated project build/preview execution is isolated by Linux user/mount/network/PID namespaces.
# Production fails closed when the sandbox is unavailable. The unsafe override is for an
# already-isolated local development machine only and must remain disabled in production.
QUANTPILOT_GENERATED_SANDBOX=1
QUANTPILOT_ALLOW_UNSANDBOXED_GENERATED_CODE=0
